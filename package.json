{
  "name": "@boozedog/pi-codemode",
  "version": "0.1.3",
  "description": "Pi Codemode plugin - TypeScript code execution with sandboxed tools, just-bash shell, and MCP integration",
  "keywords": [
    "codemode",
    "pi-extension",
    "pi-package",
    "sandbox",
    "typescript"
  ],
  "homepage": "https://github.com/boozedog/pi-codemode#readme",
  "bugs": {
    "url": "https://github.com/boozedog/pi-codemode/issues"
  },
  "license": "MIT",
  "author": "Mario Zechner and contributors",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/boozedog/pi-codemode.git"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint --deny warnings --vitest-plugin src",
    "test": "vitest run",
    "check": "npm run format:check && npm run lint && npm run build && npm test",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "publish:tag": "npm run check && npm run check:clean-tree && npm pack --dry-run && git tag v$npm_package_version && git push origin v$npm_package_version",
    "check:clean-tree": "git diff --quiet && git diff --cached --quiet || (echo \"Working tree is dirty; commit or stash changes before publishing.\" && git status --short && exit 1)",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "just-bash": "3.0.0",
    "minisearch": "^7.2.0",
    "pi-mcp-adapter": "2.5.4",
    "quickjs-emscripten": "^0.32.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@mariozechner/pi-tui": "^0.73.1",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.19.17",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
